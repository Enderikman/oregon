# Copy to `.env` (or `.env.local`) and edit. All vars are OPTIONAL — the app
# runs fully mocked when unset (data lives in src/lib/mock-data.ts).
#
# Vite only exposes vars prefixed with VITE_ to the client bundle.

# Base URL of the quiz/ingest backend. When set, src/lib/quiz-api.ts
# switches off the in-memory mock and calls real HTTP endpoints:
#   GET  {base}/open-questions?userId=...
#   POST {base}/ingest-answer
#   POST {base}/ai/clarify   (SSE)
#   POST {base}/ai/draft
# Leave empty (or omit) to keep the local mock store.
VITE_API_BASE_URL=

# OpenRouter direct integration (TESTING ONLY — exposes the key in the
# client bundle). When VITE_OPENROUTER_API_KEY is set, the quiz "ask AI"
# clarify chat and answer-draft hooks bypass VITE_API_BASE_URL and call
# https://openrouter.ai/api/v1/chat/completions directly.
VITE_OPENROUTER_API_KEY=
VITE_OPENROUTER_MODEL=openai/gpt-4o-mini

# URL of the voice-agent backend (FastAPI service in caffeinate/voice-agent).
# Required for `src/lib/speech.ts` — the dictation/synthesis bridge talks
# to this service. Defaults to localhost:8001 in development; override for
# preview/production. Without it, voice features are disabled (no Web
# Speech fallback).
VITE_VOICE_AGENT_URL=http://localhost:8001

# ──────────────────────────────────────────────────────────────────────────
# Cloudflare Worker secrets (server-side only) belong in `.dev.vars`, NOT
# this file. `.dev.vars` is read by Wrangler during `vite dev` / preview and
# is also gitignored. Example contents:
#   API_TOKEN=...
#   OPENAI_API_KEY=...
# Production secrets: `wrangler secret put <NAME>`.
