# ─────────────────────────────────────────────────────────────────────────
#  Oregon — copy to `.env`, fill keys, then:  docker compose up --build
# ─────────────────────────────────────────────────────────────────────────


# ── Backend secrets ──────────────────────────────────────────────────────

# REQUIRED. Used by the ingest pipeline and the query LLM (Gemini).
GOOGLE_API_KEY=

# Embed model (Gemini default). Override only if using a local embed server.
EMBED_MODEL=gemini-embedding-001

# OPTIONAL. Local OpenAI-compatible embed server (e.g. LM Studio).
# Blank = use Gemini API.
EMBED_ENDPOINT=


# ── Frontend secrets ─────────────────────────────────────────────────────

# REQUIRED. Backend URL as seen from the BROWSER (not from inside docker).
VITE_API_BASE_URL=http://localhost:3000

# OPTIONAL. Enables in-quiz "clarify / draft" helper (browser → OpenRouter).
VITE_OPENROUTER_API_KEY=
VITE_OPENROUTER_MODEL=openai/gpt-4o-mini


# ── Paths ────────────────────────────────────────────────────────────────
# Raw dataset (input) lives in   ./dataset/<dataset_name>/
# Ingested pages (output) go to  ./data/<dataset_name>/   ← committed to git
# On startup the backend checks if ./data has content; if empty, it ingests.

INGEST_DATA_DIR=/dataset/EnterpriseBench
OUTPUT_DIR=/data/EnterpriseBench
INGEST_ON_STARTUP=true
